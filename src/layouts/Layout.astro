---
import '../styles/global.css';
import { basics } from "@cv";

interface Props {
  title: string;
}

const { title } = Astro.props;
const { name, summary, image, url } = basics;

const site = Astro.site ?? new URL('https://gabriel-rueda.vercel.app');
const ogImage = new URL(image, site).toString();
const canonical = url || site.toString();

/* Precompute bubble props server-side so the layer is static HTML */
const bubbles = Array.from({ length: 14 }, (_, i) => ({
  left:  `${(i * 37 + 5) % 100}%`,
  size:  `${14 + ((i * 13) % 44)}px`,
  dur:   `${9  + ((i * 7)  % 11)}s`,
  delay: `-${((i * 1.7) % 12).toFixed(1)}s`,
  op:    `${(0.22 + ((i % 5) * 0.11)).toFixed(2)}`,
}));
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <title>{title}</title>
    <meta name="description" content={summary} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#FFD23F" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonical} />
    <link rel="preload" as="image" href={image} />

    <!-- Fonts: Fredoka · Bangers · Nunito -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Fredoka:wght@400;500;600;700&family=Bangers&family=Nunito:wght@400;600;700;800;900&display=swap"
    />

    <!-- Open Graph -->
    <meta property="og:url"          content={canonical} />
    <meta property="og:type"         content="website" />
    <meta property="og:title"        content={title} />
    <meta property="og:description"  content={summary} />
    <meta property="og:image"        content={ogImage} />
    <meta name="twitter:card"        content="summary_large_image" />
    <meta property="twitter:url"     content={canonical} />
    <meta name="twitter:title"       content={title} />
    <meta name="twitter:description" content={summary} />
    <meta name="twitter:image"       content={ogImage} />
  </head>
  <body>
    <!-- Fixed bubble layer behind everything -->
    <div class="bubbles-layer" aria-hidden="true">
      {bubbles.map((b) => (
        <div
          class="bubble"
          style={`left:${b.left};width:${b.size};height:${b.size};animation-duration:${b.dur};animation-delay:${b.delay};opacity:${b.op};`}
        />
      ))}
    </div>

    <slot />
  </body>
</html>

<style>
  .bubbles-layer {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    overflow: hidden;
  }

  .bubble {
    position: absolute;
    bottom: -80px;
    border-radius: 50%;
    background: radial-gradient(
      circle at 32% 28%,
      rgba(255, 255, 255, .95),
      rgba(180, 230, 255, .35) 60%,
      rgba(120, 200, 245, .15)
    );
    border: 2px solid rgba(255, 255, 255, .7);
    box-shadow: inset -2px -3px 6px rgba(70, 160, 220, .25);
    animation: bubbleRise linear infinite;
  }

  @keyframes bubbleRise {
    0%   { transform: translateY(0) translateX(0); }
    50%  { transform: translateY(-55vh) translateX(20px); }
    100% { transform: translateY(-112vh) translateX(-10px); }
  }
</style>
