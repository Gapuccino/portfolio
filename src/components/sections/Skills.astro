---
import Section from "../Section.astro";
import cv from "@cv";

const SKILLS_ICONS: Record<string, string> = {
  HTML5: "/iconos/HTML.webp",
  CSS3: "/iconos/CSS.webp",
  "JavaScript (ES6+)": "/iconos/JS.webp",
  "React 18": "/iconos/REACT.webp",
  jQuery: "/iconos/JQUERY.webp",
  Bootstrap: "/iconos/Bootstrap.webp",
  Astro: "/iconos/ASTRO.webp",
  Python: "/iconos/PYTHON.webp",
  "REST APIs": "/iconos/Fatapi.webp",
  MySQL: "/iconos/MYSQL.webp",
  "SQL Server": "/iconos/SQLSERVER.webp",
  PostgreSQL: "/iconos/Postgresql.webp",
  "Arc XP": "/iconos/ARCXP.webp",
  Strapi: "/iconos/STRAPI.webp",
  Git: "/iconos/GIT.webp",
  GitHub: "/iconos/GITHUB.webp",
  "VS Code": "/iconos/visual-studio-code-icon.webp",
  Linux: "/iconos/UBUNTU-LINUX.webp",
  Docker: "/iconos/DOCKER.webp",
  AWS: "/iconos/AWS.webp",
  Antigravity: "/iconos/antigravity.webp",
  "Core Web Vitals (LCP, TBT, CLS)": "/iconos/CWV.webp",
  Lighthouse: "/iconos/Lighthouse.webp",
  Scrum: "/iconos/Scrum.webp",
  Kanban: "/iconos/Kanban.webp",
};

interface SkillGroup {
  name: string;
  level?: string;
  keywords?: string[];
}

const groups = ((cv as any).skills || []) as SkillGroup[];
---

<Section title="Habilidades">
  <dl class="skills">
    {
      groups.map((g) => (
        <div class="row">
          <dt>
            <span class="cat">{g.name}</span>
            {g.level && <span class="level mono">{g.level}</span>}
          </dt>
          <dd>
            <ul class="tags">
              {(g.keywords || []).map((k) => {
                const iconSrc = SKILLS_ICONS[k];
                return (
                  <li class="tag mono">
                    {iconSrc && <img src={iconSrc} alt={`${k} icon`} class="skill-icon" />}
                    <span>{k}</span>
                  </li>
                );
              })}
            </ul>
          </dd>
        </div>
      ))
    }
  </dl>
</Section>

<style>
  .skills {
    margin: 0;
    display: flex;
    flex-direction: column;
  }

  .row {
    display: grid;
    grid-template-columns: minmax(9rem, 12rem) 1fr;
    gap: 1.5rem;
    padding: 1.25rem 0;
    border-top: 1px solid var(--line);
    align-items: baseline;
  }
  .row:first-child {
    border-top: none;
    padding-top: 0;
  }

  dt {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }
  .cat {
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--ink);
  }
  .level {
    font-size: 0.72rem;
    color: var(--ink-3);
  }

  dd {
    margin: 0;
  }
  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
  }
  .tag {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.82rem;
    font-weight: 500;
    color: var(--ink-2);
    background: var(--surface);
    border: 1px solid var(--line-2);
    padding: 0.35rem 0.7rem;
    border-radius: 7px;
    transition:
      border-color 0.18s var(--ease-out),
      color 0.18s var(--ease-out),
      transform 0.18s var(--ease-out);
  }
  .skill-icon {
    width: 1.2em;
    height: 1.2em;
    object-fit: contain;
  }
  .tag:hover {
    border-color: var(--accent);
    color: var(--accent-ink);
    transform: translateY(-2px);
  }

  @media (width <= 640px) {
    .row {
      grid-template-columns: 1fr;
      gap: 0.75rem;
    }
  }
</style>
