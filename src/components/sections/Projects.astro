---
import cv from "@cv";

interface ProjectExt {
  name: string;
  description?: string;
  url?: string;
  technologies?: string[];
  images?: string[];
  highlights?: string[];
  additionalLinks?: { label: string; url: string }[];
}

const projects = ((cv as any).projects || []) as ProjectExt[];

/* Tint per project (order matches cv.json projects array) */
const TINTS = ['#FFD1CC','#BEE9FF','#FFE89B','#D6F5E3','#E3E0FF','#FFE0B2','#F0F4FF'];

/* Placeholder label when no image is available */
const PLACEHOLDER: Record<string, string> = {
  'Metro Push Notifications': 'Push dashboard — interno',
  'Publimetro Shortener':     'Dashboard — proyecto interno',
};
---

<section id="proyectos" class="projects" aria-label="Proyectos">
  <div class="section-header" data-reveal>
    <span class="section-badge" style="background:var(--yellow); color:var(--navy);">PROYECTOS</span>
    <div class="section-line"></div>
  </div>

  <div class="carousel-container">
    <button class="carousel-btn prev-btn" aria-label="Proyecto anterior">
      <!-- Left arrow -->
      <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24"
        fill="none" stroke="currentColor" stroke-width="3.2"
        stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <polyline points="15 18 9 12 15 6"/>
      </svg>
    </button>

    <div class="carousel-track" data-carousel-track>
      {projects.map((p, i) => {
        const img   = p.images?.[0];
        const tint  = TINTS[i % TINTS.length];
        const links = p.additionalLinks ?? [];
        return (
          <article class="project-card hover-lift">
            <!-- Screenshot / Placeholder -->
            <div class="card-thumb" style={`background:${tint};`}>
              {img
                ? <img src={img} alt={`Vista previa de ${p.name}`} loading="lazy" decoding="async" class="thumb-img" />
                : (
                  <div class="thumb-placeholder">
                    <span class="placeholder-label">{PLACEHOLDER[p.name] ?? 'sin captura de pantalla'}</span>
                  </div>
                )
              }
            </div>

            <!-- Content -->
            <div class="card-body">
              <h3 class="card-title">{p.name}</h3>
              {p.description && <p class="card-desc">{p.description}</p>}

              {p.technologies && p.technologies.length > 0 && (
                <ul class="tech-tags" aria-label="Tecnologías usadas">
                  {p.technologies.map((t) => (
                    <li class="tech-tag">{t}</li>
                  ))}
                </ul>
              )}

              <div class="card-actions">
                {p.url
                  ? (
                    <a
                      href={p.url}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="btn-cartoon btn-green"
                      aria-label={`Ver sitio de ${p.name}`}
                    >
                      <!-- External link -->
                      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24"
                        fill="none" stroke="currentColor" stroke-width="2.5"
                        stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/>
                        <polyline points="15 3 21 3 21 9"/>
                        <line x1="10" y1="14" x2="21" y2="3"/>
                      </svg>
                      Ver sitio
                    </a>
                  )
                  : (
                    <span class="internal-badge">
                      <!-- Lock -->
                      <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24"
                        fill="none" stroke="currentColor" stroke-width="2.5"
                        stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
                        <path d="M7 11V7a5 5 0 0110 0v4"/>
                      </svg>
                      Proyecto interno
                    </span>
                  )
                }
                {links.map((lk) => (
                  <a
                    href={lk.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="btn-cartoon btn-blue"
                    aria-label={lk.label}
                  >
                    {lk.label}
                  </a>
                ))}
              </div>
            </div>
          </article>
        );
      })}
    </div>

    <button class="carousel-btn next-btn" aria-label="Siguiente proyecto">
      <!-- Right arrow -->
      <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24"
        fill="none" stroke="currentColor" stroke-width="3.2"
        stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <polyline points="9 18 15 12 9 6"/>
      </svg>
    </button>
  </div>

  <div class="carousel-dots" aria-hidden="true">
    {projects.map((_, i) => (
      <button class={`carousel-dot ${i === 0 ? 'active' : ''}`} data-index={i} aria-label={`Ir al proyecto ${i + 1}`}></button>
    ))}
  </div>
</section>

<style>
  .projects {
    position: relative;
    z-index: 1;
    max-width: 1120px;
    margin: 0 auto;
    padding: clamp(40px, 6vw, 64px) 24px;
  }

  @media (min-width: 681px) {
    .projects {
      padding: clamp(40px, 6vw, 64px) 80px;
    }
  }

  .carousel-container {
    position: relative;
    width: 100%;
  }

  .carousel-track {
    display: flex;
    gap: 26px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    scrollbar-width: none;
    padding: 12px 10px 24px 10px; /* leaves room for shadows */
    width: 100%;
  }

  .carousel-track::-webkit-scrollbar {
    display: none;
  }

  /* Buttons */
  .carousel-btn {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: var(--yellow);
    border: var(--border);
    box-shadow: var(--shadow-sm);
    cursor: pointer;
    z-index: 10;
    display: grid;
    place-items: center;
    color: var(--navy);
    transition: transform .15s var(--ease-pop), box-shadow .15s, opacity .2s, background-color .15s;
  }

  .carousel-btn:hover:not(:disabled) {
    transform: translateY(-50%) translateY(-3px) scale(1.06);
    box-shadow: var(--shadow-sm);
    background: var(--yellow-lt);
  }

  .carousel-btn:active:not(:disabled) {
    transform: translateY(-50%) translateY(1px) scale(0.97);
    box-shadow: 1px 1px 0 var(--navy);
  }

  .carousel-btn:disabled {
    opacity: 0;
    pointer-events: none;
  }

  .prev-btn {
    left: -64px;
  }

  .next-btn {
    right: -64px;
  }

  /* Dots */
  .carousel-dots {
    display: flex;
    justify-content: center;
    gap: 10px;
    margin-top: 14px;
  }

  .carousel-dot {
    width: 13px;
    height: 13px;
    border-radius: 50%;
    background: #fff;
    border: 2px solid var(--navy);
    cursor: pointer;
    padding: 0;
    transition: transform .15s var(--ease-pop), background-color .15s, box-shadow .15s;
  }

  .carousel-dot:hover {
    transform: scale(1.18);
    background: var(--yellow-lt);
  }

  .carousel-dot.active {
    background: var(--yellow);
    transform: scale(1.3);
    box-shadow: 2px 2px 0 var(--navy);
  }

  /* Card */
  .project-card {
    flex: 0 0 calc(33.333% - 18px);
    scroll-snap-align: center;
    display: flex;
    flex-direction: column;
    background: #fff;
    border: var(--border);
    border-radius: 24px;
    box-shadow: var(--shadow);
    overflow: hidden;
  }

  /* Thumbnail */
  .card-thumb {
    position: relative;
    aspect-ratio: 16 / 10;
    border-bottom: var(--border);
    overflow: hidden;
  }

  .thumb-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top center;
    display: block;
  }

  .thumb-placeholder {
    position: absolute;
    inset: 0;
    display: grid;
    place-items: center;
    background-image: repeating-linear-gradient(
      45deg,
      rgba(21, 35, 63, .1) 0 10px,
      transparent 10px 20px
    );
  }

  .placeholder-label {
    font-family: monospace;
    font-size: 13px;
    font-weight: 700;
    color: var(--navy);
    background: #fff;
    border: 2px dashed var(--navy);
    border-radius: 10px;
    padding: 8px 14px;
    text-align: center;
  }

  /* Body */
  .card-body {
    padding: 18px 20px 20px;
    display: flex;
    flex-direction: column;
    flex: 1;
    gap: 10px;
  }

  .card-title {
    font-family: var(--ff-title);
    font-size: clamp(17px, 2vw, 21px);
    font-weight: 700;
    line-height: 1.1;
    margin: 0;
  }

  .card-desc {
    font-family: var(--ff-body);
    font-size: 14px;
    font-weight: 600;
    line-height: 1.5;
    color: #3a4663;
    flex: 1;
  }

  /* Tech tags */
  .tech-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .tech-tag {
    font-family: var(--ff-title);
    font-weight: 600;
    font-size: 12px;
    background: #EAF6FF;
    border: 2px solid var(--navy);
    border-radius: var(--radius-pill);
    padding: 3px 10px;
    line-height: 1.4;
  }

  /* Actions */
  .card-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 4px;
  }

  .btn-green { background: var(--green); color: #fff; font-size: 14px; padding: 8px 16px; }
  .btn-blue  { background: var(--blue);  color: var(--navy); font-size: 14px; padding: 8px 16px; }

  .internal-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: var(--ff-title);
    font-weight: 600;
    font-size: 13px;
    color: #7a8499;
    background: #f0f2f6;
    border: 2px dashed #aeb6c6;
    border-radius: 12px;
    padding: 7px 14px;
  }

  /* Responsive breakpoints */
  @media (max-width: 991px) {
    .project-card {
      flex: 0 0 calc(50% - 13px);
      scroll-snap-align: start;
    }
  }

  @media (max-width: 680px) {
    .carousel-btn {
      display: none; /* On smaller devices, touch swipe gesture is standard and sufficient */
    }
    .carousel-track {
      gap: 20px;
    }
    .project-card {
      flex: 0 0 100%;
    }
  }
</style>

<script>
  const initCarousel = () => {
    const track = document.querySelector('[data-carousel-track]') as HTMLElement | null;
    const prevBtn = document.querySelector('.prev-btn') as HTMLButtonElement | null;
    const nextBtn = document.querySelector('.next-btn') as HTMLButtonElement | null;
    const dots = Array.from(document.querySelectorAll('.carousel-dot')) as HTMLButtonElement[];

    if (!track || !prevBtn || !nextBtn) return;

    const getCardWidth = () => {
      const card = track.firstElementChild as HTMLElement | null;
      if (!card) return 0;
      const cardWidth = card.getBoundingClientRect().width;
      const trackStyle = window.getComputedStyle(track);
      const gap = parseFloat(trackStyle.gap) || 0;
      return cardWidth + gap;
    };

    const updateCarouselState = () => {
      const scrollLeft = track.scrollLeft;
      const maxScroll = track.scrollWidth - track.clientWidth;
      
      // Infinite mode: buttons are never disabled
      prevBtn.disabled = false;
      nextBtn.disabled = false;

      // Update active dot indicators
      const cardWidth = getCardWidth();
      if (cardWidth > 0) {
        const activeIndex = Math.round(scrollLeft / cardWidth);
        const maxVisibleDots = Math.round(maxScroll / cardWidth) + 1;

        dots.forEach((dot, idx) => {
          // Hide redundant dots that scroll past maxScroll
          if (idx >= maxVisibleDots) {
            dot.style.display = 'none';
          } else {
            dot.style.display = '';
          }

          if (idx === activeIndex) {
            dot.classList.add('active');
          } else {
            dot.classList.remove('active');
          }
        });
      }
    };

    prevBtn.addEventListener('click', () => {
      const cardWidth = getCardWidth();
      const scrollLeft = track.scrollLeft;
      if (scrollLeft <= 15) {
        const maxScroll = track.scrollWidth - track.clientWidth;
        track.scrollTo({ left: maxScroll, behavior: 'smooth' });
      } else {
        track.scrollBy({ left: -cardWidth, behavior: 'smooth' });
      }
    });

    nextBtn.addEventListener('click', () => {
      const cardWidth = getCardWidth();
      const scrollLeft = track.scrollLeft;
      const maxScroll = track.scrollWidth - track.clientWidth;
      if (scrollLeft >= maxScroll - 15) {
        track.scrollTo({ left: 0, behavior: 'smooth' });
      } else {
        track.scrollBy({ left: cardWidth, behavior: 'smooth' });
      }
    });

    // Listeners for manual scrolling/swiping
    track.addEventListener('scroll', updateCarouselState, { passive: true });
    window.addEventListener('resize', updateCarouselState, { passive: true });

    // Initial state
    updateCarouselState();

    // Dot navigation
    dots.forEach((dot) => {
      dot.addEventListener('click', () => {
        const index = parseInt(dot.getAttribute('data-index') || '0', 10);
        const cardWidth = getCardWidth();
        track.scrollTo({ left: index * cardWidth, behavior: 'smooth' });
      });
    });
  };

  // Run on startup
  initCarousel();
</script>
