---
import { basics } from "@cv";

const { name, label, image, email, profiles } = basics;
const github = profiles.find((p) => p.network === "GitHub")?.url;

/* Split name into two display lines */
const parts = name.split(' ');
const mid   = Math.ceil(parts.length / 2);
const line1 = parts.slice(0, mid).join(' ');
const line2 = parts.slice(mid).join(' ');

/* Floating tech stickers around the porthole */
const heroTags = [
  { label: 'React',      bg: '#36BFF0', color: '#15233F', top: '5%',  left: '-3%', rot: '-8deg',  dur: '5.5s', delay: '0s'   },
  { label: 'Astro',      bg: '#FF6F61', color: '#fff',    top: '1%',  left: '65%', rot: '7deg',   dur: '6s',   delay: '-1s'  },
  { label: 'Python',     bg: '#2FB86B', color: '#fff',    top: '47%', left: '88%', rot: '5deg',   dur: '5s',   delay: '-2s'  },
  { label: 'PostgreSQL', bg: '#15233F', color: '#fff',    top: '83%', left: '68%', rot: '-5deg',  dur: '6.5s', delay: '-1.5s'},
  { label: 'Next.js',    bg: '#1E7FC2', color: '#fff',    top: '79%', left: '-7%', rot: '6deg',   dur: '5.8s', delay: '-3s'  },
];
---

<section id="inicio" class="hero" aria-label="Presentación">

  <!-- ── Text column ── -->
  <div class="hero-text">
    <span class="greeting-badge" aria-label="Saludo">¡Hola, soy!</span>

    <h1 class="hero-name" aria-label={name}>
      {line1}<br />{line2}
    </h1>

    <div class="role-badge">{label}</div>

    <p class="hero-summary">
      Construyo interfaces modernas, rápidas y bien hechas. Me especializo
      en rendimiento (Core Web Vitals), código limpio y conectar un buen
      frontend con backend sólido.
    </p>

    <div class="hero-actions">
      <a href="#proyectos" class="btn-cartoon btn-yellow">
        <!-- Arrow right -->
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24"
          fill="none" stroke="currentColor" stroke-width="2.5"
          stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="5" y1="12" x2="19" y2="12"/>
          <polyline points="12 5 19 12 12 19"/>
        </svg>
        Ver proyectos
      </a>
      <a href="#contacto" class="btn-cartoon btn-coral">
        <!-- Mail -->
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24"
          fill="none" stroke="currentColor" stroke-width="2.5"
          stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect x="2" y="4" width="20" height="16" rx="2"/>
          <path d="M22 7l-10 7L2 7"/>
        </svg>
        Contáctame
      </a>
    </div>

    <div class="hero-links">
      {github && (
        <a href={github} target="_blank" rel="noopener noreferrer"
           class="icon-link" aria-label="Perfil de GitHub">
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22"
            viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/>
          </svg>
        </a>
      )}
      {email && (
        <a href={`mailto:${email}`} class="email-link">{email}</a>
      )}
    </div>
  </div>

  <!-- ── Photo column ── -->
  <div class="hero-photo-wrap" aria-hidden="true">
    <!-- Floating tech tags -->
    {heroTags.map((t) => (
      <div
        class="hero-tag"
        style={`top:${t.top};left:${t.left};background:${t.bg};color:${t.color};--tag-rot:${t.rot};animation-duration:${t.dur};animation-delay:${t.delay};`}
      >
        {t.label}
      </div>
    ))}

    <!-- Porthole -->
    <div class="porthole">
      <div class="porthole-ring">
        <img
          src={image}
          alt={`Foto de ${name}`}
          width="400"
          height="400"
          loading="eager"
          decoding="async"
          class="porthole-img"
        />
        <div class="porthole-shine"></div>
      </div>
      <!-- Remaches -->
      <div class="rivet rivet--tl"></div>
      <div class="rivet rivet--tr"></div>
      <div class="rivet rivet--bl"></div>
      <div class="rivet rivet--br"></div>
    </div>
  </div>

  <!-- Scroll hint -->
  <div class="scroll-hint" aria-hidden="true">
    <div class="scroll-container">
      <div class="scroll-pill">
        <div class="scroll-dot"></div>
      </div>
      <div class="scroll-arrows">
        <span class="scroll-arrow"></span>
        <span class="scroll-arrow"></span>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    z-index: 1;
    max-width: 1120px;
    margin: 0 auto;
    min-height: auto;
    padding: clamp(40px, 5vw, 64px) 24px clamp(50px, 6vw, 70px);
    display: grid;
    grid-template-columns: 1.05fr .95fr;
    grid-template-rows: auto auto;
    gap: clamp(16px, 3vw, 36px);
    align-items: center;
    align-content: center;
  }

  /* ── Text ── */
  .hero-text {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .greeting-badge {
    display: inline-block;
    font-family: var(--ff-comic);
    font-size: 22px;
    letter-spacing: 1.5px;
    color: #fff;
    background: var(--coral);
    border: var(--border);
    border-radius: 14px;
    box-shadow: 4px 4px 0 var(--navy);
    padding: 5px 16px;
    transform: rotate(-3deg);
    animation: wiggleSoft 3.5s ease-in-out infinite;
    margin-bottom: 16px;
  }

  .hero-name {
    font-family: var(--ff-title);
    font-weight: 700;
    font-size: clamp(42px, 7vw, 82px);
    line-height: .96;
    letter-spacing: -1px;
    color: var(--navy);
    text-shadow: 4px 5px 0 var(--blue);
    margin-bottom: 12px;
  }

  .role-badge {
    display: inline-block;
    font-family: var(--ff-title);
    font-weight: 600;
    font-size: clamp(17px, 2.5vw, 26px);
    color: #fff;
    background: var(--blue);
    border: var(--border);
    border-radius: 13px;
    box-shadow: 4px 4px 0 var(--navy);
    padding: 5px 18px;
    transform: rotate(1.5deg);
    white-space: nowrap;
    margin-bottom: 22px;
  }

  .hero-summary {
    font-family: var(--ff-body);
    font-size: clamp(15px, 1.8vw, 18px);
    font-weight: 600;
    line-height: 1.6;
    color: #28354f;
    max-width: 480px;
    margin-bottom: 28px;
  }

  .hero-actions {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
    margin-bottom: 24px;
  }

  .btn-yellow { background: var(--yellow); color: var(--navy); }
  .btn-coral  { background: var(--coral);  color: #fff; }

  .hero-links {
    display: flex;
    gap: 14px;
    align-items: center;
    flex-wrap: wrap;
  }

  .icon-link {
    display: grid;
    place-items: center;
    width: 46px;
    height: 46px;
    background: #fff;
    border: var(--border);
    border-radius: 50%;
    box-shadow: var(--shadow-sm);
    transition: transform .16s var(--ease-pop);
  }
  .icon-link:hover { transform: translateY(-4px) rotate(-8deg); }

  .email-link {
    font-family: var(--ff-title);
    font-weight: 600;
    font-size: 15px;
    color: var(--navy);
    border-bottom: 3px solid var(--yellow);
    padding-bottom: 2px;
    transition: border-color .15s;
  }
  .email-link:hover { border-color: var(--coral); }

  /* ── Photo ── */
  .hero-photo-wrap {
    position: relative;
    display: grid;
    place-items: center;
    min-height: 440px;
  }

  .hero-tag {
    position: absolute;
    z-index: 4;
    font-family: var(--ff-title);
    font-weight: 700;
    font-size: 15px;
    border: var(--border);
    border-radius: var(--radius-pill);
    box-shadow: var(--shadow-sm);
    padding: 7px 15px;
    white-space: nowrap;
    transform: rotate(var(--tag-rot, 0deg));
    animation: floatTag 5.5s ease-in-out infinite;
  }

  .porthole {
    position: relative;
    width: min(360px, 76vw);
    aspect-ratio: 1;
    animation: bob 5s ease-in-out infinite;
  }

  .porthole-ring {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    background: var(--blue);
    border: 11px solid var(--navy);
    box-shadow:
      9px 12px 0 rgba(21, 35, 63, .22),
      inset 0 0 0 6px #2a9fd6;
    overflow: hidden;
  }

  .porthole-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 18%;
  }

  .porthole-shine {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    background: radial-gradient(
      circle at 28% 22%,
      rgba(255, 255, 255, .55),
      rgba(255, 255, 255, 0) 42%
    );
    pointer-events: none;
  }

  .rivet {
    position: absolute;
    width: 17px;
    height: 17px;
    background: #cfd8e6;
    border: 3px solid var(--navy);
    border-radius: 50%;
  }
  .rivet--tl { top: 6%;    left: 6%;   }
  .rivet--tr { top: 6%;    right: 6%;  }
  .rivet--bl { bottom: 6%; left: 6%;   }
  .rivet--br { bottom: 6%; right: 6%;  }

  /* ── Scroll hint ── */
  .scroll-hint {
    grid-column: 1 / -1;
    display: flex;
    justify-content: center;
    padding-top: 12px;
  }

  .scroll-container {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
  }

  .scroll-pill {
    display: grid;
    place-items: start center;
    width: 30px;
    height: 48px;
    border: var(--border);
    border-radius: 16px;
    padding-top: 6px;
    background: #fff;
    box-shadow: var(--shadow-sm);
    animation: scrollPillBounce 2s ease-in-out infinite;
    position: relative;
  }

  .scroll-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--coral);
    border: 1.5px solid var(--navy);
    animation: scrollDotRubbery 1.8s cubic-bezier(0.25, 1, 0.5, 1) infinite;
    transform-origin: center top;
  }

  .scroll-arrows {
    display: flex;
    flex-direction: column;
    align-items: center;
    margin-top: 2px;
  }

  .scroll-arrow {
    display: block;
    width: 9px;
    height: 9px;
    border-right: 3px solid var(--navy);
    border-bottom: 3px solid var(--navy);
    transform: rotate(45deg);
    margin: -2px 0;
    opacity: 0;
    animation: scrollArrowBounce 1.6s infinite;
  }

  .scroll-arrow:nth-child(2) {
    animation-delay: 0.25s;
  }

  @keyframes scrollPillBounce {
    0%, 100% {
      transform: translateY(0) scale(1, 1);
    }
    45% {
      transform: translateY(4px) scale(0.95, 1.05);
    }
    50% {
      transform: translateY(5px) scale(1.06, 0.88);
    }
    55% {
      transform: translateY(4px) scale(0.95, 1.05);
    }
  }

  @keyframes scrollDotRubbery {
    0% {
      transform: translateY(0) scale(1, 1);
      opacity: 0;
    }
    10% {
      transform: translateY(0) scale(1, 1);
      opacity: 1;
    }
    75% {
      transform: translateY(18px) scale(0.85, 1.3);
      opacity: 1;
    }
    85%, 100% {
      transform: translateY(20px) scale(1, 0.6);
      opacity: 0;
    }
  }

  @keyframes scrollArrowBounce {
    0% {
      opacity: 0;
      transform: rotate(45deg) translate(-3px, -3px);
    }
    30% {
      opacity: 1;
    }
    60% {
      opacity: 0;
      transform: rotate(45deg) translate(3px, 3px);
    }
    100% {
      opacity: 0;
    }
  }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .hero {
      grid-template-columns: 1fr;
      grid-template-rows: auto;
      min-height: auto;
      padding: clamp(30px, 4vw, 40px) 20px clamp(28px, 5vw, 40px);
    }
    .hero-photo-wrap {
      order: -1;
      min-height: 300px;
    }
    .porthole { width: min(260px, 70vw); }
    .hero-tag  { font-size: 13px; padding: 5px 12px; }
  }
</style>
