---
import Section from "../Section.astro"

import { education } from "@cv"
---

<Section title="Educación">
  <ul class="edu">
    {
      education.map(({ institution, startDate, endDate, area, studyType }) => {
        const startYear = new Date(startDate).getFullYear()
        const endYear =
          endDate != null ? new Date(endDate).getFullYear() : "Actual"

        return (
          <li class="item">
            <div class="when mono">
              {startYear}<span class="when__sep">—</span>{endYear}
            </div>
            <div class="body">
              <h3>{institution}</h3>
              <p class="area">
                {studyType ? `${studyType} · ${area}` : area}
              </p>
            </div>
          </li>
        )
      })
    }
  </ul>
</Section>

<style>
  .edu {
    display: flex;
    flex-direction: column;
  }
  .item {
    display: grid;
    grid-template-columns: 7.5rem 1fr;
    gap: 1.5rem;
    padding: 1.5rem 0;
    border-top: 1px solid var(--line);
  }
  .item:first-child {
    border-top: none;
    padding-top: 0;
  }
  .when {
    font-size: 0.85rem;
    color: var(--ink-3);
    padding-top: 0.15rem;
  }
  .when__sep {
    margin: 0 0.4rem;
    color: var(--line-2);
  }
  h3 {
    font-size: 1.15rem;
    font-weight: 700;
  }
  .area {
    font-size: 0.95rem;
    margin-top: 0.25rem;
    color: var(--ink-2);
  }

  @media (width <= 640px) {
    .item {
      grid-template-columns: 1fr;
      gap: 0.4rem;
    }
  }
</style>
