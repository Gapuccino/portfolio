---
import { work } from "@cv";

const MONTHS = ['Ene','Feb','Mar','Abr','May','Jun','Jul','Ago','Sep','Oct','Nov','Dic'];
const fmt = (d: string | null) => {
  if (!d) return 'Actual';
  const [y, m] = d.split('-');
  return `${MONTHS[parseInt(m) - 1]} ${y}`;
};

const BADGE_COLORS = ['#2FB86B', '#36BFF0', '#FF6F61', '#FFD23F', '#1E7FC2'];

const jobs = work.map((j, i) => ({
  ...j,
  period: `${fmt(j.startDate)} — ${fmt(j.endDate)}`,
  badgeColor: BADGE_COLORS[i % BADGE_COLORS.length],
  badgeTextColor: BADGE_COLORS[i % BADGE_COLORS.length] === '#FFD23F' ? '#15233F' : '#fff',
}));
---

<section id="experiencia" class="experience-scroll-section" style={`height: ${jobs.length * 100}vh;`} aria-label="Experiencia">
  <!-- Checkpoints for scroll-snapping page-by-page inside the sticky wrapper -->
  {jobs.map((_, i) => (
    <div class="snap-checkpoint" data-checkpoint={i} style={`top: ${i * 100}vh;`}></div>
  ))}

  <!-- Sticky content container -->
  <div class="sticky-container">
    <div class="experience-header-sticky">
      <div class="section-header">
        <span class="section-badge" style="background:var(--blue); color:#fff;">EXPERIENCIA</span>
        <div class="section-line"></div>
      </div>
    </div>

    <div class="experience-slider-track">
      <div class="experience-slider-cards" data-experience-cards>
        {jobs.map((job) => (
          <article class="job-card hover-lift">
            <!-- Period badge (absolute, floats above top edge) -->
            <div
              class="period-badge"
              style={`background:${job.badgeColor}; color:${job.badgeTextColor};`}
            >
              {job.period}
            </div>

            <h3 class="job-org">
              {job.url
                ? <a href={job.url} target="_blank" rel="noopener noreferrer" class="job-link">{job.name}</a>
                : <span>{job.name}</span>
              }
            </h3>
            <p class="job-role">{job.position}</p>

            {job.summary && <p class="job-summary">{job.summary}</p>}

            {job.highlights && job.highlights.length > 0 && (
              <ul class="highlights">
                {job.highlights.map((h) => (
                  <li class="highlight-item">
                    <span class="bullet" aria-hidden="true"></span>
                    <span>{h}</span>
                  </li>
                ))}
              </ul>
            )}
          </article>
        ))}
      </div>
    </div>

    <!-- Progress indicator dots -->
    <div class="experience-progress">
      {jobs.map((_, i) => (
        <button
          class={`progress-dot ${i === 0 ? 'active' : ''}`}
          data-progress={i}
          aria-label={`Ver puesto ${i + 1}`}
        ></button>
      ))}
    </div>
  </div>
</section>

<style>
  .experience-scroll-section {
    position: relative;
    /* Height is dynamic via inline style */
    display: block !important; /* overrides global flex section style */
  }

  .snap-checkpoint {
    position: absolute;
    left: 0;
    width: 100%;
    height: 100vh;
    scroll-snap-align: start;
    pointer-events: none;
    z-index: 0;
  }

  .sticky-container {
    position: sticky;
    top: 68px;
    height: calc(100vh - 68px);
    display: flex;
    flex-direction: column;
    justify-content: center;
    overflow: hidden;
    box-sizing: border-box;
    padding: 40px 24px;
    z-index: 10;
  }

  .experience-header-sticky {
    max-width: 1000px;
    width: 100%;
    margin: 0 auto 24px auto;
  }

  .experience-slider-track {
    max-width: 1000px;
    width: 100%;
    margin: 0 auto;
    overflow: hidden;
    padding: 24px 16px 36px 16px; /* increased to leave room for the hover animation */
  }

  .experience-slider-cards {
    display: flex;
    transition: transform 0.6s cubic-bezier(0.25, 1, 0.5, 1);
    width: 100%;
    gap: 40px; /* spacing between slides when scrolling */
  }

  .experience-slider-cards .job-card {
    flex: 0 0 100%;
    width: 100%;
    box-sizing: border-box;
    margin-top: 14px;
    background: #fff;
    border: var(--border);
    border-radius: 22px;
    box-shadow: var(--shadow);
    padding: 26px 28px 24px;
    position: relative;
  }

  /* Progress indicators */
  .experience-progress {
    display: flex;
    justify-content: center;
    gap: 10px;
    margin-top: 20px;
  }

  .progress-dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: #fff;
    border: 2px solid var(--navy);
    cursor: pointer;
    padding: 0;
    transition: transform .15s var(--ease-pop), background-color .15s, box-shadow .15s;
  }

  .progress-dot:hover {
    transform: scale(1.18);
    background: var(--yellow-lt);
  }

  .progress-dot.active {
    background: var(--blue);
    transform: scale(1.3);
    box-shadow: 2px 2px 0 var(--navy);
  }

  /* Card inner elements (original styles) */
  .period-badge {
    position: absolute;
    top: -14px;
    left: 22px;
    font-family: var(--ff-title);
    font-weight: 700;
    font-size: 14px;
    border: var(--border);
    border-radius: var(--radius-pill);
    box-shadow: var(--shadow-sm);
    padding: 4px 14px;
    white-space: nowrap;
  }

  .job-org {
    font-family: var(--ff-title);
    font-size: clamp(19px, 2.5vw, 24px);
    font-weight: 700;
    margin: 8px 0 2px;
  }

  .job-link {
    color: inherit;
    transition: color .15s;
  }
  .job-link:hover { color: var(--blue-deep); }

  .job-role {
    font-family: var(--ff-title);
    font-weight: 600;
    font-size: 16px;
    color: var(--blue-deep);
    margin-bottom: 12px;
  }

  .job-summary {
    font-family: var(--ff-body);
    font-size: 15px;
    font-weight: 600;
    line-height: 1.55;
    color: #3a4663;
    margin-bottom: 14px;
  }

  .highlights {
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .highlight-item {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    font-family: var(--ff-body);
    font-size: 14px;
    font-weight: 600;
    line-height: 1.45;
    color: #28354f;
  }

  .bullet {
    flex-shrink: 0;
    margin-top: 4px;
    width: 13px;
    height: 13px;
    border-radius: 50%;
    background: var(--yellow);
    border: 2px solid var(--navy);
  }

  /* Responsive tweaks */
  @media (max-width: 768px) {
    .sticky-container {
      padding: 24px 16px;
    }
    .experience-header-sticky {
      margin-bottom: 20px;
    }
    .job-card {
      padding: 22px 20px 20px;
    }
  }

  @media (max-width: 480px) {
    .sticky-container {
      padding: 16px 12px;
    }
    .job-summary {
      font-size: 14px;
      margin-bottom: 10px;
    }
    .highlight-item {
      font-size: 13px;
    }
  }
</style>

<script>
  const initExperienceScroll = () => {
    const checkpoints = Array.from(document.querySelectorAll('.snap-checkpoint')) as HTMLElement[];
    const cardsContainer = document.querySelector('[data-experience-cards]') as HTMLElement | null;
    const dots = Array.from(document.querySelectorAll('.experience-progress .progress-dot')) as HTMLButtonElement[];
    const section = document.querySelector('.experience-scroll-section') as HTMLElement | null;

    if (!section || checkpoints.length === 0 || !cardsContainer) return;

    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const idx = parseInt(entry.target.getAttribute('data-checkpoint') || '0', 10);
          
          // Translate the cards container: accounts for 100% width + 40px gap
          cardsContainer.style.transform = `translateX(calc(-${idx * 100}% - ${idx * 40}px))`;
          
          // Update active dot indicators
          dots.forEach((dot, dIdx) => {
            if (dIdx === idx) {
              dot.classList.add('active');
            } else {
              dot.classList.remove('active');
            }
          });
        }
      });
    }, {
      threshold: 0.5,
      rootMargin: '-68px 0px 0px 0px' // accounts for the fixed navbar height
    });

    checkpoints.forEach((cp) => observer.observe(cp));

    // Dots click navigation
    dots.forEach((dot, idx) => {
      dot.addEventListener('click', () => {
        checkpoints[idx].scrollIntoView({ behavior: 'smooth' });
      });
    });
  };

  // Run on startup
  initExperienceScroll();
</script>
