---
import Section from "../Section.astro";

import { work } from "@cv";

const METRO_SITES = [
  { url: "https://www.publimetro.com.mx/" },
  { url: "https://www.publimetro.co/" },
  { url: "https://www.metroecuador.com.ec/" },
  { url: "https://www.publimetro.cl/" },
  { url: "https://www.publinews.gt/" },
  { url: "https://www.fayerwayer.com/" },
  { url: "https://www.nuevamujer.com/" },
  { url: "https://www.ferplei.com/" },
  { url: "https://www.elcalce.com/" },
  { url: "https://www.metroworldnews.com/" },
  { url: "https://www.metro.pr/" },
  { url: "https://www.sagrosso.com/" },
];
---

<Section title="Experiencia">
  <ul class="timeline">
    {
      work.map(
        ({ name, startDate, endDate, position, summary, highlights, url }) => {
          const startYear = new Date(startDate).getFullYear();
          const isCurrent = endDate == null;
          const endYear = isCurrent
            ? "Actual"
            : new Date(endDate).getFullYear();

          return (
            <li class:list={["item", { "is-current": isCurrent }]}>
              <div class="when mono">
                <span>{startYear}</span>
                <span class="when__sep">—</span>
                <span class={isCurrent ? "when__now" : ""}>{endYear}</span>
              </div>

              <div class="body">
                <h3 class="org">
                  {name === "Metro World News (Publimetro)" ? (
                    <button class="link metro-trigger" type="button">
                      {name}
                      <span class="org__hint mono">12 sitios ↗</span>
                    </button>
                  ) : url ? (
                    <a class="link" href={url} target="_blank" rel="noopener">
                      {name}
                    </a>
                  ) : (
                    <span>{name}</span>
                  )}
                </h3>
                <p class="role">{position}</p>
                {summary && <p class="summary">{summary}</p>}
                {highlights && highlights.length > 0 && (
                  <ul class="highlights">
                    {highlights.map((h) => (
                      <li>{h}</li>
                    ))}
                  </ul>
                )}
              </div>
            </li>
          );
        },
      )
    }
  </ul>

  <dialog id="metro-modal" class="no-print">
    <div class="modal">
      <header class="modal__head">
        <h3>Metro World News</h3>
        <button id="close-metro-btn" type="button" aria-label="Cerrar">
          &times;
        </button>
      </header>
      <ul class="sites">
        {
          METRO_SITES.map((site) => (
            <li>
              <a href={site.url} target="_blank" rel="noopener noreferrer">
                <span class="mono">
                  {site.url.replace(/^https?:\/\/(www\.)?/, "").replace("/", "")}
                </span>
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </dialog>
</Section>

<script is:inline>
  function setupMetroModal() {
    const dialog = document.getElementById("metro-modal");
    const trigger = document.querySelector(".metro-trigger");
    const close = document.getElementById("close-metro-btn");
    if (!dialog || !trigger) return;

    const open = (e) => {
      e.preventDefault();
      dialog.showModal();
      document.body.style.overflow = "hidden";
    };
    const shut = () => {
      dialog.close();
      document.body.style.overflow = "";
    };

    trigger.addEventListener("click", open);
    close?.addEventListener("click", shut);
    dialog.addEventListener("click", (e) => {
      if (e.target === dialog) shut();
    });
  }

  setupMetroModal();
  document.addEventListener("astro:page-load", setupMetroModal);
</script>

<style>
  .timeline {
    display: flex;
    flex-direction: column;
  }

  .item {
    display: grid;
    grid-template-columns: 7.5rem 1fr;
    gap: 1.5rem;
    padding: 1.75rem 0;
    border-top: 1px solid var(--line);
  }
  .item:first-child {
    border-top: none;
    padding-top: 0;
  }

  .when {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
    font-size: 0.85rem;
    color: var(--ink-3);
    padding-top: 0.2rem;
  }
  .when__sep {
    color: var(--line-2);
  }
  .when__now {
    color: var(--accent-ink);
    font-weight: 600;
  }

  .org {
    font-size: 1.2rem;
    font-weight: 700;
    display: flex;
    align-items: center;
    gap: 0.6rem;
    flex-wrap: wrap;
  }

  .is-current .org::before {
    content: "";
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--accent);
    flex-shrink: 0;
  }

  .link {
    background: none;
    border: none;
    padding: 0;
    font: inherit;
    color: inherit;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    transition: color 0.18s var(--ease-out);
  }
  .link:hover {
    color: var(--accent-ink);
  }

  .org__hint {
    font-size: 0.7rem;
    font-weight: 500;
    color: var(--accent-ink);
    background: var(--accent-tint);
    padding: 0.15rem 0.5rem;
    border-radius: 999px;
  }

  .role {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--ink);
    margin-top: 0.2rem;
  }

  .summary {
    font-size: 0.95rem;
    margin-top: 0.5rem;
    max-width: var(--measure);
  }

  .highlights {
    margin-top: 0.85rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    max-width: var(--measure);
  }
  .highlights li {
    position: relative;
    padding-left: 1.25rem;
    font-size: 0.9rem;
    line-height: 1.5;
    color: var(--ink-2);
  }
  .highlights li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0.55em;
    width: 6px;
    height: 6px;
    border-radius: 1px;
    background: var(--accent);
    transform: rotate(45deg);
  }

  @media (width <= 640px) {
    .item {
      grid-template-columns: 1fr;
      gap: 0.6rem;
    }
    .when {
      flex-direction: row;
      gap: 0.4rem;
      padding-top: 0;
    }
  }

  /* Modal */
  dialog {
    padding: 0;
    border: none;
    background: transparent;
    max-width: min(92vw, 560px);
    color: var(--ink);
  }
  dialog::backdrop {
    background: oklch(0.99 0.005 50 / 0.7);
    backdrop-filter: blur(8px);
  }
  .modal {
    background: var(--surface);
    border: 1px solid var(--line-2);
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 24px 60px oklch(0.2 0.02 45 / 0.18);
  }
  .modal__head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.1rem 1.25rem;
    border-bottom: 1px solid var(--line);
  }
  .modal__head h3 {
    font-size: 1.05rem;
  }
  #close-metro-btn {
    background: var(--bg-2);
    border: 1px solid var(--line);
    width: 32px;
    height: 32px;
    border-radius: 8px;
    font-size: 1.3rem;
    line-height: 1;
    cursor: pointer;
    color: var(--ink-2);
    transition: all 0.18s var(--ease-out);
  }
  #close-metro-btn:hover {
    background: var(--accent-tint);
    color: var(--accent-ink);
  }
  .sites {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.5rem;
    padding: 1rem;
    max-height: 60vh;
    overflow-y: auto;
  }
  .sites a {
    display: block;
    padding: 0.7rem 0.8rem;
    border: 1px solid var(--line);
    border-radius: 9px;
    font-size: 0.8rem;
    color: var(--ink-2);
    transition: all 0.18s var(--ease-out);
  }
  .sites a:hover {
    border-color: var(--accent);
    color: var(--accent-ink);
    background: var(--accent-tint);
  }
</style>
