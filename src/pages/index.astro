---
import Layout from "@/layouts/Layout.astro";
import Nav from "@/components/Nav.astro";
import Mascota from "@/components/Mascota.astro";

import Hero       from "@/components/sections/Hero.astro";
import About      from "@/components/sections/About.astro";
import Experience from "@/components/sections/Experience.astro";
import Projects   from "@/components/sections/Projects.astro";
import Skills     from "@/components/sections/Skills.astro";
import Education  from "@/components/sections/Education.astro";
import Contact    from "@/components/sections/Contact.astro";

import { basics } from "@cv";
const { name, label } = basics;
---

<Layout title={`${name} — ${label}`}>
  <Nav />

  <main>
    <Hero />
    <About />
    <Experience />
    <Projects />
    <Skills />
    <Education />
    <Contact />
  </main>

  <Mascota />
</Layout>

<!-- Scroll reveal: set hidden via JS so no-JS still shows content -->
<script>
  const reveal = () => {
    const els = Array.from(document.querySelectorAll('[data-reveal]')) as HTMLElement[];

    /* Hide them only if JS is available */
    els.forEach((el) => {
      el.style.opacity = '0';
      el.style.transform = 'translateY(28px) scale(.92)';
      el.style.willChange = 'transform, opacity';
    });

    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) {
            const el = e.target as HTMLElement;
            el.style.animation = 'popReveal .6s cubic-bezier(.34,1.56,.64,1) forwards';
            io.unobserve(el);
          }
        });
      },
      { threshold: 0.14 }
    );

    els.forEach((el) => io.observe(el));
  };

  /* Run once on initial load */
  reveal();
</script>

<style>
  main {
    /* Push below fixed nav (~68px) */
    padding-top: 68px;
    position: relative;
    z-index: 1;
  }
</style>
